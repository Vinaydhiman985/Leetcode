class Solution {
    public int removeElement(int[] nums, int val) {
        int k=0;
        for(int i=0; i<nums.length;i++){
            if(nums[i]!= val){
                swap(nums,i,k);
                k++;
            }
        }   return k;
    }
 public static void swap(int arr[], int i, int j){
         int temp = arr[i];
         arr[i] = arr[j];
         arr[j] =  temp;
  }    
}           
    
